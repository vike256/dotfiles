# Start by ignoring all
*

# Allow .gitignore and README.md
!.gitignore
!README.md
!debian.sh

# Allow git to open .config
!.config/

# Allow git to open .config/nvim/
# Full path to files needs to be allowed folder by folder
!.config/nvim/
!.config/nvim/*

# Repeat above for all relevant folders
!.config/tmux/
!.config/tmux/*
